---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us">
	<section class="pt-32 pb-20 px-6 max-w-4xl mx-auto">
		<h1 class="text-4xl md:text-5xl font-bold text-white mb-8">About Lifetime Fitness Club</h1>
		<div class="prose prose-invert max-w-none text-gray-400">
			<p class="text-lg mb-6">Founded on the belief that health is the ultimate wealth, Lifetime Fitness Club has redefined the workout experience for professionals.</p>
			<p class="mb-6">Our club brings together state-of-the-art equipment, holistic recovery services, and a passionate team of trainers to help you achieve your absolute best.</p>
			<p>We are more than a gym. We are a lifestyle. Come join us.</p>
		</div>
	</section>
</Layout>
