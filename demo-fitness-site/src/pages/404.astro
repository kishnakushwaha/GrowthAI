---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found">
	<section class="min-h-[70vh] flex items-center justify-center px-6">
		<div class="text-center">
			<h1 class="text-7xl font-bold text-white mb-4">404</h1>
			<h2 class="text-2xl text-gray-400 mb-8">Page Not Found</h2>
			<p class="text-gray-500 mb-8 max-w-md mx-auto">The page you are looking for doesn't exist or has been moved.</p>
			<a href="/" class="px-6 py-3 bg-white text-black font-medium rounded-md hover:bg-gray-200 transition-colors">Go Back Home</a>
		</div>
	</section>
</Layout>
