---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium Fitness Club">
	<!-- Hero Section -->
	<section class="relative pt-32 pb-20 px-6 overflow-hidden">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gray-900 via-black to-black -z-10"></div>
		
		<div class="max-w-4xl mx-auto text-center">
			<h1 class="text-5xl md:text-7xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500 mb-6">
				Elevate Your Fitness Journey
			</h1>
			<p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
				Experience world-class equipment, elite personal training, and a community dedicated to peak performance. Welcome to Lifetime Fitness Club.
			</p>
			
			<div class="flex gap-4 justify-center">
				<a href="/contact" class="px-6 py-3 bg-white text-black font-medium rounded-md hover:bg-gray-200 transition-colors">Start Free Trial</a>
				<a href="#services" class="px-6 py-3 bg-transparent border border-white/20 text-white font-medium rounded-md hover:bg-white/5 transition-colors">Explore Facilities</a>
			</div>
		</div>
	</section>

	<!-- Services Grid -->
	<section id="services" class="py-24 px-6 border-t border-white/5">
		<div class="max-w-6xl mx-auto">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-bold text-white mb-4">Premium Amenities</h2>
				<p class="text-gray-400 max-w-2xl mx-auto">Everything you need to reach your goals, all under one roof.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<!-- Card 1 -->
				<div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-gray-500 transition-colors backdrop-blur-sm">
					<div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-3">Elite Training</h3>
					<p class="text-sm text-gray-400">Work 1-on-1 with certified experts to build a program tailored exactly to your body.</p>
				</div>
				<!-- Card 2 -->
				<div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-gray-500 transition-colors backdrop-blur-sm">
					<div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-3">Group Classes</h3>
					<p class="text-sm text-gray-400">From high-intensity interval training (HIIT) to restorative yoga and Pilates.</p>
				</div>
				<!-- Card 3 -->
				<div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-gray-500 transition-colors backdrop-blur-sm">
					<div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path></svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-3">Luxury Recovery</h3>
					<p class="text-sm text-gray-400">Accelerate your results with our infrared saunas, cold plunges, and massage therapy.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Testimonials -->
	<section class="py-24 px-6 bg-white/5">
		<div class="max-w-4xl mx-auto text-center">
			<svg class="w-10 h-10 text-gray-500 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
			<h3 class="text-2xl md:text-4xl font-medium text-white mb-8">"Switching to Lifetime was the best decision I made. The equipment is flawless, and the community keeps me motivated every single day."</h3>
			<div class="flex items-center justify-center gap-4">
				<div class="w-12 h-12 bg-gray-800 rounded-full"></div>
				<div class="text-left">
					<p class="text-white font-bold">Sarah Jenkins</p>
					<p class="text-sm text-gray-500">Member since 2024</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-24 px-6 border-t border-white/5">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-3xl font-bold text-white mb-10 text-center">Frequently Asked Questions</h2>
			
			<div class="space-y-6">
				<div class="border border-white/10 rounded-lg p-6 bg-white/5">
					<h4 class="text-lg font-bold text-white mb-2">What are your operating hours?</h4>
					<p class="text-gray-400">We are open 24/7 for all premium members, so you can work out on your own schedule.</p>
				</div>
				<div class="border border-white/10 rounded-lg p-6 bg-white/5">
					<h4 class="text-lg font-bold text-white mb-2">Are group classes included in the membership?</h4>
					<p class="text-gray-400">Yes! All standard memberships include unlimited access to our daily group fitness classes.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
