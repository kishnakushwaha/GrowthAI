---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium Architecture">
	<!-- Hero Section -->
	<section class="relative pt-32 pb-20 px-6 overflow-hidden">
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gray-900 via-black to-black -z-10"></div>
		
		<div class="max-w-4xl mx-auto text-center">
			<h1 class="text-5xl md:text-7xl font-bold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500 mb-6">
				Designing the Future of Architecture in NCR
			</h1>
			<p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
				Award-winning architectural design, interior planning, and landscape architecture. We turn spaces into experiences.
			</p>
			
			<div class="flex gap-4 justify-center">
				<a href="/contact" class="px-6 py-3 bg-white text-black font-medium rounded-md hover:bg-gray-200 transition-colors">Start Your Project</a>
				<a href="#portfolio" class="px-6 py-3 bg-transparent border border-white/20 text-white font-medium rounded-md hover:bg-white/5 transition-colors">View Portfolio</a>
			</div>
		</div>
	</section>

	<!-- Services Grid -->
	<section id="services" class="py-24 px-6 border-t border-white/5">
		<div class="max-w-6xl mx-auto">
			<div class="text-center mb-16">
				<h2 class="text-3xl font-bold text-white mb-4">Our Services</h2>
				<p class="text-gray-400 max-w-2xl mx-auto">Comprehensive architectural solutions tailored for modern living and cutting-edge commercial spaces.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				<!-- Card 1 -->
				<div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-gray-500 transition-colors backdrop-blur-sm">
					<div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-3">Architecture</h3>
					<p class="text-sm text-gray-400">Concept-to-completion architectural design for residential and commercial projects.</p>
				</div>
				<!-- Card 2 -->
				<div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-gray-500 transition-colors backdrop-blur-sm">
					<div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-3">Interior Design</h3>
					<p class="text-sm text-gray-400">Bespoke interior spaces that balance aesthetics, functionality, and modern luxury.</p>
				</div>
				<!-- Card 3 -->
				<div class="p-8 rounded-xl bg-white/5 border border-white/10 hover:border-gray-500 transition-colors backdrop-blur-sm">
					<div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center mb-6">
						<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					</div>
					<h3 class="text-xl font-bold text-white mb-3">Master Planning</h3>
					<p class="text-sm text-gray-400">Large-scale urban planning and landscape architecture for sustainable developments.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Testimonials -->
	<section class="py-24 px-6 bg-white/5">
		<div class="max-w-4xl mx-auto text-center">
			<svg class="w-10 h-10 text-gray-500 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" /></svg>
			<h3 class="text-2xl md:text-4xl font-medium text-white mb-8">"The team at 42MM completely transformed our vision into reality. Their attention to detail and modern aesthetic is unmatched in the NCR region."</h3>
			<div class="flex items-center justify-center gap-4">
				<div class="w-12 h-12 bg-gray-800 rounded-full"></div>
				<div class="text-left">
					<p class="text-white font-bold">Rahul Sharma</p>
					<p class="text-sm text-gray-500">CEO, Skyline Developers</p>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ Section -->
	<section class="py-24 px-6 border-t border-white/5">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-3xl font-bold text-white mb-10 text-center">Frequently Asked Questions</h2>
			
			<div class="space-y-6">
				<div class="border border-white/10 rounded-lg p-6 bg-white/5">
					<h4 class="text-lg font-bold text-white mb-2">What regions do you serve?</h4>
					<p class="text-gray-400">We primarily serve clients across the Delhi NCR region, including Noida, Gurgaon, and Ghaziabad.</p>
				</div>
				<div class="border border-white/10 rounded-lg p-6 bg-white/5">
					<h4 class="text-lg font-bold text-white mb-2">Do you handle commercial projects?</h4>
					<p class="text-gray-400">Yes, our portfolio includes luxury residential, high-end commercial, and large-scale master planning projects.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
