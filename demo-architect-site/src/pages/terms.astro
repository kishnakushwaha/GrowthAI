---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Terms & Conditions">
	<section class="pt-32 pb-20 px-6 max-w-4xl mx-auto">
		<h1 class="text-4xl font-bold text-white mb-8">Terms & Conditions</h1>
		<div class="prose prose-invert max-w-none text-gray-400">
			<p class="mb-4">Last updated: {new Date().toLocaleDateString()}</p>
			<h2 class="text-2xl text-white font-semibold mt-8 mb-4">1. Acceptance of Terms</h2>
			<p class="mb-4">By accessing and using this website, you accept and agree to be bound by the terms and provision of this agreement.</p>
			<h2 class="text-2xl text-white font-semibold mt-8 mb-4">2. Intellectual Property</h2>
			<p class="mb-4">All architectural designs, renderings, and content on this website are the intellectual property of 42MM Architecture.</p>
		</div>
	</section>
</Layout>
